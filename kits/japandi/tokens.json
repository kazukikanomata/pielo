{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "Japandi — pielo worldview kit",
  "version": "0.1.0",
  "color": {
    "bg": { "$value": "#EFE9DE", "$description": "背景(生成り)" },
    "surface": { "$value": "#F5F1E8", "$description": "カード面" },
    "surface-2": { "$value": "#E9E2D4", "$description": "第二面" },
    "ink": { "$value": "#3A3733", "$description": "本文(炭)" },
    "ink-soft": { "$value": "#77705F", "$description": "補助文字" },
    "ink-faint": { "$value": "#9A917F", "$description": "弱い文字" },
    "accent": { "$value": "#8A8F79", "$description": "苔。線と小さな図形のみ" },
    "accent-warm": { "$value": "#CBB99A", "$description": "砂。背景の変化用" },
    "line": { "$value": "rgba(58,55,51,0.16)", "$description": "罫線" }
  },
  "typography": {
    "heading-family": { "$value": "Shippori Mincho, Cormorant Garamond, serif" },
    "body-family": { "$value": "Zen Kaku Gothic New, Karla, sans-serif" },
    "heading-weight": { "$value": 500 },
    "body-weight": { "$value": 400 },
    "heading-tracking": { "$value": "0.28em" },
    "wide-tracking": { "$value": "0.45em" },
    "body-leading": { "$value": 2.0 }
  },
  "radius": {
    "default": { "$value": "2px" },
    "max": { "$value": "4px", "$description": "これ以上丸めない" }
  },
  "shadow": {
    "default": { "$value": "none", "$description": "影は使わない。面の色差で分ける" }
  },
  "spacing": {
    "section": { "$value": "clamp(96px, 14vh, 160px)" },
    "card-inner": { "$value": "44px" }
  },
  "motion": {
    "transition": { "$value": "0.3s ease-out", "$description": "静かな遷移のみ" }
  },
  "rules": {
    "forbidden": [
      "原色・ネオン・高彩度色",
      "純白 #FFFFFF / 純黒 #000000",
      "ドロップシャドウ",
      "グラデーション",
      "8px超の角丸",
      "太字(700+)の見出し",
      "塗りつぶしボタン"
    ]
  }
}
